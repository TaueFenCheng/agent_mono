{
  "name": "@intelligent-agent/desktop-electron",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:renderer\" \"pnpm dev:electron\"",
    "dev:renderer": "vite --port 1421 --strictPort",
    "dev:electron": "wait-on tcp:1421 && electron .",
    "build": "pnpm build:renderer && electron-builder --dir",
    "build:renderer": "vite build",
    "lint": "echo 'desktop-electron lint skipped'",
    "test": "vitest run --passWithNoTests",
    "fix:electron": "ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ node ./node_modules/electron/install.js"
  },
  "dependencies": {
    "@intelligent-agent/ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.intelligent.agent.electron",
    "productName": "intelligentAgent",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        "dir"
      ]
    }
  }
}
