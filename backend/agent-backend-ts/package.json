{
  "name": "@intelligent-agent/agent-backend-ts",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm prisma:generate && tsc-watch --onSuccess \"node dist/main.js\"",
    "prisma:generate": "prisma generate",
    "dev:debugger": "tsx --inspect watch src/main.ts",
    "prisma:push": "prisma db push",
    "build": "pnpm run prisma:generate && tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "vitest run",
    "lint": "echo 'agent-backend-ts lint skipped'"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1056.0",
    "@aws-sdk/s3-request-presigner": "^3.1056.0",
    "@intelligent-agent/agent-core": "workspace:*",
    "@intelligent-agent/core-types": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^6.8.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.41.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "exceljs": "^4.4.0",
    "ioredis": "^5.4.1",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tesseract.js": "^7.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "prisma": "^6.8.2",
    "ts-node": "^10.9.2",
    "tsc-watch": "^7.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
