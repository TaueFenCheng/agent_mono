# ── Stage 1: Install dependencies & build shared packages ──
FROM node:22-bookworm-slim AS builder

RUN corepack enable && corepack prepare pnpm@10.28.0 --activate
RUN pnpm config set registry https://registry.npmmirror.com

WORKDIR /app

# Copy everything needed for dependency resolution
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/core-types/package.json    packages/core-types/
COPY core/agent-core-ts/package.json     core/agent-core-ts/
COPY packages/sdk-ts/package.json        packages/sdk-ts/
COPY packages/ui/package.json            packages/ui/
COPY backend/agent-backend-ts/package.json backend/agent-backend-ts/

# Copy source files (needed so pnpm can resolve workspace dependencies)
COPY tsconfig.base.json ./
COPY packages/core-types/    packages/core-types/
COPY core/agent-core-ts/     core/agent-core-ts/
COPY packages/sdk-ts/        packages/sdk-ts/
COPY packages/ui/            packages/ui/
COPY backend/agent-backend-ts/ backend/agent-backend-ts/

# Install all dependencies (including devDependencies for build)
RUN pnpm install --frozen-lockfile

# Build in dependency order (prisma generate is part of backend build)
RUN pnpm --filter @intelligent-agent/core-types build && \
    pnpm --filter @intelligent-agent/agent-core build && \
    pnpm --filter @intelligent-agent/sdk-ts build && \
    pnpm --filter @intelligent-agent/ui build && \
    pnpm --filter @intelligent-agent/agent-backend-ts build

# ── Stage 2: Production image ──
FROM node:22-bookworm-slim AS runner

RUN corepack enable && corepack prepare pnpm@10.28.0 --activate
RUN pnpm config set registry https://registry.npmmirror.com

# Install OpenSSL (required by Prisma engine)
RUN apt-get update -y && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy workspace manifests
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/core-types/package.json    packages/core-types/
COPY core/agent-core-ts/package.json     core/agent-core-ts/
COPY packages/sdk-ts/package.json        packages/sdk-ts/
COPY packages/ui/package.json            packages/ui/
COPY backend/agent-backend-ts/package.json backend/agent-backend-ts/

# Install ALL dependencies (prisma is a devDependency needed at runtime for generate)
RUN pnpm install --frozen-lockfile

# Copy built artifacts
COPY --from=builder /app/packages/core-types/dist/  packages/core-types/dist/
COPY --from=builder /app/core/agent-core-ts/dist/   core/agent-core-ts/dist/
COPY --from=builder /app/packages/sdk-ts/dist/       packages/sdk-ts/dist/
COPY --from=builder /app/packages/ui/                packages/ui/
COPY --from=builder /app/backend/agent-backend-ts/dist/      backend/agent-backend-ts/dist/
COPY --from=builder /app/backend/agent-backend-ts/prisma/    backend/agent-backend-ts/prisma/

# Generate Prisma client in production image (prisma CLI available via full install)
RUN cd backend/agent-backend-ts && pnpm exec prisma generate

ENV NODE_ENV=production
ENV NEST_PORT=8080

EXPOSE 8080

CMD ["node", "backend/agent-backend-ts/dist/main.js"]
